{
  "name": "defaults-explorer",
  "productName": "defaults-explorer",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "build:renderer": "esbuild src/renderer/main.jsx --bundle --format=iife --platform=browser --outfile=src/renderer.bundle.js --loader:.js=jsx",
    "prestart": "npm run build:renderer",
    "start": "electron-forge start",
    "prepackage": "npm run build:renderer",
    "package": "electron-forge package",
    "premake": "npm run build:renderer",
    "make": "electron-forge make",
    "prepublish": "npm run build:renderer",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
